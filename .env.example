# Legal MCP Server -- example environment configuration.
# Copy to `.env` and fill in as needed. All integrations are OFF by default.

# --- Server ---
# HOST=127.0.0.1
# PORT=8000
# MCP_TRANSPORT=sse        # stdio | sse | streamable-http
# LOG_LEVEL=INFO

# --- Bundled demo content ------------------------------------------------
# OFF by default. When enabled, bundled sample cases, statutes, and contracts
# are exposed with explicit DEMO DATA warnings. Never treat them as verified
# legal authority or user-supplied content.
LEGAL_MCP_DEMO_MODE=false

# --- Feature flags (tool categories) --------------------------------------
# All categories are ON by default. Set any of these to `false` to disable
# an entire tool category (its tools -- and matching resources -- will not
# be registered). There is no hard floor: disabling everything leaves a
# server with zero tools.
# LEGAL_MCP_ENABLE_RESEARCH=true
# LEGAL_MCP_ENABLE_CITATION=true
# LEGAL_MCP_ENABLE_CONTRACT=true
# LEGAL_MCP_ENABLE_DOCUMENT=true
# LEGAL_MCP_ENABLE_PRIVILEGE=true
# LEGAL_MCP_ENABLE_BRIEF=true
# LEGAL_MCP_ENABLE_ANALYSIS_QUEUE=true   # set to false to disable the local SQLite job queue
LEGAL_MCP_ENABLE_INTEGRATIONS=true

# --- CourtListener / RECAP (Free Law Project) -----------------------------
# Free, rate-limited, and the preferred live source. Create a free account
# and generate a token at https://www.courtlistener.com/profile/api/
COURTLISTENER_ENABLED=false
COURTLISTENER_API_TOKEN=
# COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4

# --- PACER (federal court records) ----------------------------------------
# WARNING: PACER is a PAID service and may incur per-page/per-search fees.
# Automated agents can exhaust a standard account's quarterly fee waiver
# quickly. Leave disabled unless you understand the billing implications.
# QA is a separate, non-billable test environment (register at
# https://qa-pacer.uscourts.gov). Production registration:
# https://pacer.uscourts.gov
PACER_ENABLED=false
PACER_ENVIRONMENT=qa        # qa (non-billable test) | production (billable)
PACER_LOGIN_ID=
PACER_PASSWORD=
PACER_CLIENT_CODE=          # optional
PACER_OTP_SECRET=           # optional base32 TOTP secret if 2FA is enabled
